# Application configuration
# Example: APP_NAME=WorkflowManagerAPI
APP_NAME=WorkflowManagerAPI

# Administrator's email for system notifications
# Example: ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL=example@example.com

# Server configuration
# Hostname of the server (do not include 'http://')
# Example: BASE_HOST=localhost
BASE_HOST=localhost
# Server Port on which the server will listen
BASE_PORT_WORKFLOWMANAGER=5050

# Internal application port, not to be changed
BASE_PORT=5050

# Complete base URL of the API (including protocol and port)
# Example: BASE_URL=http://localhost:5050
BASE_URL=0.0.0.0:5050

# Database name
# Example "jni"
DB_NAME=workflow

# Database configuration
# Example: DB_URL=mongodb://localhost:27017/mydatabase
DB_URL=mongodb://mongoAdmin:mongoPassword@mongo:27000/workflow

# Deployment environment (dev, prod)
# Example: ENVIRONMENT=dev
ENVIRONMENT=dev

## Get stdout from python process
PYTHONUNBUFFERED=1