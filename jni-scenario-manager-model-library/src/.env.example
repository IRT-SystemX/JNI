# Application configuration
# Example: APP_NAME=WorkflowManagerAPI
APP_NAME=<app_name_here>

# Administrator's email for system notifications
# Example: ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL=<admin_email_here>

# Server configuration
# Hostname of the server (do not include 'http://')
# Example: BASE_HOST=localhost
BASE_HOST=<base_host_here>

# Port on which the server will listen
# Example: BASE_PORT=5050
BASE_PORT=<base_port_here>

# Complete base URL of the API (including protocol and port)
# Example: BASE_URL=http://localhost:5050
BASE_URL=<base_url_here>

# Database name
# Example "jni"
DB_NAME=<database_name_here>

# Database configuration
# Example: DB_URL=mongodb://localhost:27017/mydatabase
DB_URL=<database_url_here>

# Deployment environment (dev, prod)
# Example: ENVIRONMENT=dev
ENVIRONMENT=<environment_here>

# Allowed origins for CORS (Cross-Origin Resource Sharing)
# Comma-separated list of URLs
# Example: ALLOWED_ORIGINS=http://localhost,http://localhost:3000,https://example.com
ALLOWED_ORIGINS=<comma_separated_url_list_here>
